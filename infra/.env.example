# ----- Domains (NetAngels DNS A-records -> VPS IP) -----
APP_DOMAIN=app.if-x.ru
API_DOMAIN=api.if-x.ru
LIVEKIT_DOMAIN=livekit.if-x.ru

# ----- LiveKit -----
# Generate with: openssl rand -hex 16
LIVEKIT_API_KEY=REPLACE_ME_API_KEY
# Generate with: openssl rand -hex 32
LIVEKIT_API_SECRET=REPLACE_ME_API_SECRET

# ----- coturn (TURN server) -----
# Generate with: openssl rand -hex 24
TURN_SECRET=REPLACE_ME_TURN_SECRET

# ----- Let's Encrypt -----
ACME_EMAIL=your-email@example.com
