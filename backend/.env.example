# ----- LiveKit credentials (must match infra/.env) -----
LIVEKIT_API_KEY=REPLACE_ME_API_KEY
LIVEKIT_API_SECRET=REPLACE_ME_API_SECRET

# Public WebSocket URL clients connect to
LIVEKIT_URL=wss://livekit.if-x.ru

# ----- CORS -----
# Comma-separated list of origins allowed to call the API.
# Include local dev origins so React dev server works.
CORS_ORIGINS=https://app.if-x.ru,http://localhost:5173,http://localhost:3000

# ----- Token settings -----
# Access-token TTL in minutes
TOKEN_TTL_MINUTES=60
